@model AppointmentDTO
@{
    ViewData["Title"] = "Delete Appointment";
}
 
<h2>Delete Appointment</h2>
<p>Are you sure you want to delete this appointment?</p>
<p><b>@Model.PatientName</b> with <b>@Model.DoctorName</b> on @Model.AppointmentDate</p>
 
<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.AppointmentId" />
    <button type="submit" name="decision" value="Yes" class="btn btn-danger">Yes</button>
    <button type="submit" name="decision" value="No" class="btn btn-secondary">No</button>
</form>
