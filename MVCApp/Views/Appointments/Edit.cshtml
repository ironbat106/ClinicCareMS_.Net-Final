@model AppointmentDTO
@{
    ViewData["Title"] = "Edit Appointment";
}
 
<h2>Edit Appointment</h2>
<form asp-action="Edit" method="post">
    <input asp-for="AppointmentId" type="hidden" />
    <input asp-for="CreatedAt" type="hidden" />
    <input asp-for="Status" type="hidden" />
    <div asp-validation-summary="All" class="text-danger"></div>
 
    <div class="mb-3">
        <label asp-for="PatientId">Patient</label>
        <select asp-for="PatientId" asp-items="ViewBag.PatientId" class="form-control"></select>
    </div>
 
    <div class="mb-3">
        <label asp-for="DoctorId">Doctor</label>
        <select asp-for="DoctorId" asp-items="ViewBag.DoctorId" class="form-control"></select>
    </div>
 
    <div class="mb-3"><label asp-for="AppointmentDate"></label><input asp-for="AppointmentDate" type="datetime-local" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Reason"></label><input asp-for="Reason" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Fee"></label><input asp-for="Fee" type="number" step="1" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Notes"></label><textarea asp-for="Notes" class="form-control"></textarea></div>
 
    <button type="submit" class="btn btn-primary">Update</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
