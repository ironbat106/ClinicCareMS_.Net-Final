@model AppointmentDTO
@{
    ViewData["Title"] = "Create Appointment";
}
 
<h2>Create Appointment</h2>
<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
 
    <div class="mb-3">
        <label asp-for="PatientId">Patient</label>
        <select asp-for="PatientId" asp-items="ViewBag.PatientId" class="form-control">
            <option value="0">-- Select Patient --</option>
        </select>
    </div>
 
    <div class="mb-3">
        <label asp-for="DoctorId">Doctor</label>
        <select asp-for="DoctorId" asp-items="ViewBag.DoctorId" class="form-control">
            <option value="0">-- Select Doctor --</option>
        </select>
    </div>
 
    <div class="mb-3"><label asp-for="AppointmentDate"></label><input asp-for="AppointmentDate" type="datetime-local" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Reason"></label><input asp-for="Reason" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Fee"></label><input asp-for="Fee" type="number" step="1" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Notes"></label><textarea asp-for="Notes" class="form-control"></textarea></div>
 
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
