@model List<PatientDTO>
@{
    ViewData["Title"] = "Patients";
}
 
<h2>Patients</h2>
<a asp-action="Create" class="btn btn-primary mb-2">Create Patient</a>
 
<table class="table table-bordered table-striped">
    <tr>
        <th>Name</th>
        <th>Phone</th>
        <th>Email</th>
        <th>Date of Birth</th>
        <th>Actions</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Phone</td>
            <td>@item.Email</td>
            <td>@item.DateOfBirth?.ToString("yyyy-MM-dd")</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.PatientId">Details</a> |
                <a asp-action="Edit" asp-route-id="@item.PatientId">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.PatientId">Delete</a>
            </td>
        </tr>
    }
</table>
