@model PatientDTO
@{
    ViewData["Title"] = "Create Patient";
}
 
<h2>Create Patient</h2>
<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-3"><label asp-for="Name"></label><input asp-for="Name" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Phone"></label><input asp-for="Phone" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Email"></label><input asp-for="Email" class="form-control" /></div>
    <div class="mb-3"><label asp-for="DateOfBirth"></label><input asp-for="DateOfBirth" type="date" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Address"></label><textarea asp-for="Address" class="form-control"></textarea></div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
