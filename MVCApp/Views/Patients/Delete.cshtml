@model PatientDTO
@{
    ViewData["Title"] = "Delete Patient";
}
 
<h2>Delete Patient</h2>
<p>Are you sure you want to delete this patient?</p>
<p><b>@Model.Name</b> - @Model.Phone</p>
 
<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.PatientId" />
    <button type="submit" name="decision" value="Yes" class="btn btn-danger">Yes</button>
    <button type="submit" name="decision" value="No" class="btn btn-secondary">No</button>
</form>
