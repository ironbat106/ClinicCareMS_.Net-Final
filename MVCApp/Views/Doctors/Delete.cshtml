@model DoctorDTO
@{
    ViewData["Title"] = "Delete Doctor";
}
 
<h2>Delete Doctor</h2>
<p>Are you sure you want to delete this doctor?</p>
<p><b>@Model.Name</b> - @Model.Specialization</p>
 
<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.DoctorId" />
    <button type="submit" name="decision" value="Yes" class="btn btn-danger">Yes</button>
    <button type="submit" name="decision" value="No" class="btn btn-secondary">No</button>
</form>
